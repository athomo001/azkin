          ]
        },
        "options": {}
      },
      "id": "cdca1914-32de-4c2c-93b0-2281f8cb3e21",
      "name": "Listar monitores (Azkin)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300],
      "notes": "GET /api/public/v1/monitors — requiere scope 'read'. Autenticación vía header X-API-Key (ver docs/api-publica.md)."
    }
  ],
  "connections": {
    "Cada 5 minutos": {
      "main": [
        [
          { "node": "Listar monitores (Azkin)", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "pinData": {},
  "meta": {
    "description": "Workflow de ejemplo: cada 5 minutos consulta la API pública de Azkin (AZ-029) y trae el estado de todos los monitores. Configura las variables de entorno de n8n AZKIN_BASE_URL (ej. https://tu-dominio.com) y AZKIN_API_KEY (una key generada en /settings → API, scope 'read' basta) antes de activar el workflow."
  },
  "settings": {
    "executionOrder": "v1"
  }
}
