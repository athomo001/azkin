# Imagen de DESARROLLO local (hot-reload con tsx watch).
# Para producción usa el Dockerfile multi-stage (build + runtime slim).
FROM node:20-alpine
WORKDIR /app

# iputils provee un binario `ping` compatible con el checker ICMP
RUN apk add --no-cache iputils

# Instala dependencias en una capa cacheable
COPY package*.json ./
RUN npm ci

# El código fuente se monta como volumen en compose.dev.yaml,
# por lo que aquí solo copiamos como fallback para ejecución standalone.
COPY . .

EXPOSE 3000
CMD ["npm", "run", "dev"]
