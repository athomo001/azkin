# Puerto del servidor HTTP
AZKIN_PORT=3000

# Conexión a MongoDB (requiere MongoDB >= 5.0 para Time Series Collections)
AZKIN_MONGO_URI=mongodb://localhost:27017/azkin

# Secreto para firmar los JWT (OBLIGATORIO — cámbialo en producción)
AZKIN_JWT_SECRET=change-me-in-production

# Expiración del access token, en segundos (default 2 h)
AZKIN_JWT_EXPIRES_IN=7200

# Concurrencia máxima de checks simultáneos (p-limit)
AZKIN_CHECK_CONCURRENCY=50

# Retardo del primer check tras agendar un monitor, en ms
AZKIN_FIRST_CHECK_DELAY_MS=1000

# Umbral de latencia (ms) sobre el cual un monitor HTTP que responde OK pasa a DEGRADADO
# en vez de UP, sin esperar a que falle por timeout.
AZKIN_DEGRADED_LATENCY_MS=5000

# Intervalo de chequeo (segundos) mientras un monitor está DOWN o DEGRADADO — se restaura
# al intervalo normal configurado apenas el monitor vuelve a responder UP.
AZKIN_ACCELERATED_INTERVAL_SECONDS=15

# Origen permitido para CORS y Socket.io (frontend). Requerido explícitamente:
# usa "*" solo si es una decisión consciente para desarrollo, nunca en producción.
AZKIN_CORS_ORIGIN=*

# Costo de bcrypt para el hash de contraseñas (4-15). Default 10.
AZKIN_BCRYPT_COST=10

# Credenciales de /metrics (Prometheus). Sin valor por defecto — si ninguna de las
# dos formas de autenticación está configurada, /metrics queda inaccesible (fail-closed).
# Basic Auth (usar AMBAS):
AZKIN_PROMETHEUS_USER=
AZKIN_PROMETHEUS_PASS=
# o alternativamente, API Key por header X-API-Key (si se define, deshabilita Basic Auth):
AZKIN_PROMETHEUS_API_KEY=

# Clave de 32 bytes en hex (64 caracteres) para cifrar en reposo la clave privada TLS y la
# identidad de federación. OPCIONAL: si se deja vacía, se deriva automáticamente de
# AZKIN_JWT_SECRET (no requiere ningún paso manual, ni siquiera en despliegues multi-nodo/multi-
# región — cada nodo deriva la suya). Fijar esta variable solo si querés una clave independiente
# del JWT secret. Un valor mal formado no tumba el backend (AZ-041): solo deshabilita esta
# función, con advertencia en el log. Generar con el botón "Generar clave independiente" en
# /settings → TLS/Sistema, o a mano con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AZKIN_TLS_ENCRYPTION_KEY=

# Puerto dedicado del listener mTLS de federación de instancias (default 8444). Solo tiene efecto
# si AZKIN_TLS_ENCRYPTION_KEY está configurado. También se puede cambiar en caliente, sin reiniciar
# el contenedor, desde /settings → Multi-Región — este valor es solo el usado hasta que un Admin
# guarde un puerto distinto desde ahí.
AZKIN_FEDERATION_PORT=8444

# SMTP a nivel de aplicación para correos transaccionales (recuperación de contraseña).
# Si se deja vacío, los correos se registran en el log (modo mock) en vez de enviarse.
AZKIN_SMTP_HOST=
AZKIN_SMTP_PORT=587
AZKIN_SMTP_SECURE=false
AZKIN_SMTP_USER=
AZKIN_SMTP_PASSWORD=
AZKIN_SMTP_FROM=

# URL pública del frontend, usada para construir el enlace de recuperación de contraseña.
AZKIN_APP_URL=http://localhost:4200
