# Puerto del servidor HTTP
AZKIN_PORT=3000

# Conexión a MongoDB (requiere MongoDB >= 5.0 para Time Series Collections)
AZKIN_MONGO_URI=mongodb://localhost:27017/azkin

# Secreto para firmar los JWT (OBLIGATORIO — cámbialo en producción)
AZKIN_JWT_SECRET=change-me-in-production

# Expiración del access token, en segundos (default 2 h)
AZKIN_JWT_EXPIRES_IN=7200

# Concurrencia máxima de checks simultáneos (p-limit)
AZKIN_CHECK_CONCURRENCY=50

# Retardo del primer check tras agendar un monitor, en ms
AZKIN_FIRST_CHECK_DELAY_MS=1000

# Origen permitido para CORS y Socket.io (frontend). Requerido explícitamente:
# usa "*" solo si es una decisión consciente para desarrollo, nunca en producción.
AZKIN_CORS_ORIGIN=*

# Costo de bcrypt para el hash de contraseñas (4-15). Default 10.
AZKIN_BCRYPT_COST=10

# Credenciales de /metrics (Prometheus). Sin valor por defecto — si ninguna de las
# dos formas de autenticación está configurada, /metrics queda inaccesible (fail-closed).
# Basic Auth (usar AMBAS):
AZKIN_PROMETHEUS_USER=
AZKIN_PROMETHEUS_PASS=
# o alternativamente, API Key por header X-API-Key (si se define, deshabilita Basic Auth):
AZKIN_PROMETHEUS_API_KEY=

# Clave de 32 bytes en hex (64 caracteres) para cifrar en reposo la clave privada TLS
# subida desde la UI de administración. Requerida solo si se configura HTTPS nativo.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AZKIN_TLS_ENCRYPTION_KEY=

# SMTP a nivel de aplicación para correos transaccionales (recuperación de contraseña).
# Si se deja vacío, los correos se registran en el log (modo mock) en vez de enviarse.
AZKIN_SMTP_HOST=
AZKIN_SMTP_PORT=587
AZKIN_SMTP_SECURE=false
AZKIN_SMTP_USER=
AZKIN_SMTP_PASSWORD=
AZKIN_SMTP_FROM=

# URL pública del frontend, usada para construir el enlace de recuperación de contraseña.
AZKIN_APP_URL=http://localhost:4200
