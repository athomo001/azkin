# ==============================================================================
# CONFIGURACIÓN GENERAL DEL MONOREPO - AZKIN (PLANTILLA EJEMPLO)
# Copia este archivo como .env en la raíz del proyecto para configurarlo localmente.
#
# Arquitectura de red: azkin-db, azkin-back y azkin-front comparten la red Docker
# dedicada `azkin-network` (bridge). Todos los puertos publicados en el host son
# configurables (ninguno hardcodeado en el compose) — cámbialos si ya usas alguno
# en otro proyecto del mismo servidor.
# ==============================================================================

# --- Puertos expuestos en el host ---
# Puerto del backend (API REST + WebSockets). El puerto interno del contenedor
# es siempre 3000 (fijo, no configurable — ver compose.yaml).
AZKIN_BACK_PORT=3000
AZKIN_FRONTEND_PORT=80
# Puerto HTTPS nativo del backend. Debe coincidir con el puerto que se configure
# desde la UI de administración (Configuración > TLS/HTTPS) para que quede accesible:
# el backend escucha internamente en el puerto que el admin elija ahí, no en un valor
# fijo del Dockerfile, así que el mapeo host:contenedor usa esta misma variable en ambos lados.
AZKIN_HTTPS_PORT=8443
# Puerto de MongoDB en el host, solo para depuración/administración directa (Compass,
# mongosh, migraciones). Enlazado únicamente a 127.0.0.1 (ver compose.yaml) — no queda
# alcanzable desde la red externa, solo desde el propio servidor. Cámbialo si ya tienes
# otro Mongo escuchando en 27017 en esta máquina; para uso normal de Azkin no hace falta
# tocarlo, el backend siempre se conecta internamente vía azkin-db:27017.
AZKIN_MONGO_PORT=27017

# --- Base de datos ---
# AZKIN_MONGO_URI ya no se define aquí: se construye automáticamente en el compose
# a partir de estas dos variables y del nombre del servicio interno (azkin-db:27017),
# para evitar mantener una URI duplicada y potencialmente desincronizada.
#
# IMPORTANTE: la URI se arma pegando estas variables directamente como texto (sin
# URL-encoding), así que una contraseña con caracteres especiales (@ : / % ? #) puede
# romper el parseo de la conexión de forma silenciosa y confusa (el error no menciona la
# contraseña). Genera una contraseña segura y solo alfanumérica con:
#   openssl rand -hex 24
AZKIN_MONGO_USER=azkin_admin
AZKIN_MONGO_PASSWORD=CambiarEstaContrasenaDeMongoSegura123!

# --- JWT ---
# Clave secreta para firmar y validar tokens. ¡Cambiar en producción!
AZKIN_JWT_SECRET=tu-clave-secreta-muy-segura-aqui

# Tiempo de expiración del token en segundos (7200 = 2 horas)
AZKIN_JWT_EXPIRES_IN=7200

# Costo de bcrypt para el hash de contraseñas. Default: 10. Subir en producción
# de alto riesgo, bajar solo en tests para acelerar la suite.
AZKIN_BCRYPT_COST=10

# --- Prometheus Metrics ---
# Autenticación Básica por defecto (deshabilitada si se define una API Key)
AZKIN_PROMETHEUS_USER=prom_scraper
AZKIN_PROMETHEUS_PASS=PrometheusScraperSecurePass123!
# API Key (Si se define, inhabilita la Autenticación Básica obligatoriamente)
AZKIN_PROMETHEUS_API_KEY=

# --- Motor de monitoreo ---
# Límite de verificaciones concurrentes activas (p-limit)
AZKIN_CHECK_CONCURRENCY=50

# Tiempo de gracia inicial antes del primer chequeo (ms)
AZKIN_FIRST_CHECK_DELAY_MS=1000

# Umbral de latencia (ms) sobre el cual un monitor HTTP que responde OK pasa a DEGRADADO
# en vez de UP, sin esperar a que falle por timeout.
AZKIN_DEGRADED_LATENCY_MS=5000

# Intervalo de chequeo (segundos) mientras un monitor está DOWN o DEGRADADO — se restaura
# al intervalo normal configurado apenas el monitor vuelve a responder UP.
AZKIN_ACCELERATED_INTERVAL_SECONDS=15

# --- CORS ---
# Orígenes permitidos para peticiones HTTP y conexiones Socket.io
AZKIN_CORS_ORIGIN=*

# --- TLS/HTTPS nativo ---
# Clave de 32 bytes en hex (64 caracteres) para cifrar en reposo la clave privada TLS.
# Requerida solo si configuras HTTPS desde la UI de administración. Un valor mal formado no
# tumba el backend: solo deshabilita esta función puntual, con una advertencia en el log.
# Generar con el botón "Generar clave" en /settings → TLS/Sistema (recomendado, copia el valor
# correcto sin comandos), o a mano con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AZKIN_TLS_ENCRYPTION_KEY=

# ==============================================================================
# PRIMER ADMINISTRADOR (SEEDER INICIAL)
# El backend crea este admin automáticamente al arrancar, solo si AZKIN_FIRST_ADMIN_EMAIL
# no corresponde ya a un usuario existente (no se re-ejecuta si ya usaste estas mismas
# credenciales antes). Puedes iniciar sesión tanto con el EMAIL como con el NOMBRE de
# abajo (se guarda como nombre de usuario) — ambos son válidos en el campo "Correo o Usuario".
# ==============================================================================
AZKIN_FIRST_ADMIN_NAME=Administrador
AZKIN_FIRST_ADMIN_EMAIL=admin@azkin.local
AZKIN_FIRST_ADMIN_PASSWORD=CambiarEstaContrasenaSegura123!
